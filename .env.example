# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — keys never leave your machine.

# ---- Supabase ----
# Project URL — from Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# anon (public) key — safe to ship to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service-role key — server-side ONLY; bypasses RLS; never put in NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY=

# ---- Anthropic API ----
# Used server-side only, for PDF parsing in /api/parse
ANTHROPIC_API_KEY=

# ---- App ----
# Used by Supabase Auth for redirect callbacks
NEXT_PUBLIC_APP_URL=http://localhost:3000
